includes:
    - vendor/larastan/larastan/extension.neon

parameters:

    paths:
        - app/
        - database/
        - routes/
        - tests/

    # Level 9 is the highest level
    level: 8

    ignoreErrors:
        # - '#PHPDoc tag @var# '

    excludePaths:
        # - ./*/*/FileToBeExcluded.php

    checkMissingIterableValueType: false
